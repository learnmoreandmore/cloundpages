{
  "name": "web-vue",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"npm run dev:host\" \"wait-on tcp:5173 && electron .\"",
    "desktop:dist": "npm run build && electron . --dist",
    "desktop:pack:dir": "npm run build && electron-builder --dir",
    "desktop:build:win": "npm run build && electron-builder --win nsis",
    "desktop:build:win:gametest": "npm run build && electron-builder --win nsis --config.directories.output=\"D:/edgedownload/gametest\"",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write ./**/*.{vue,js,jsx,json,css,scss}"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.8",
    "element-plus": "^2.7.2",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.23.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.2.5",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.1",
    "terser": "^5.46.1",
    "vite": "^5.2.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "build": {
    "appId": "com.kingofcanvas.desktop",
    "productName": "King of Canvas",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
